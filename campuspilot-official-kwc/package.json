{
    "name": "campuspilot-official-kwc",
    "version": "1.0.0",
    "description": "CampusPilot official KWC custom control for Kingdee Cosmic integration",
    "scripts": {
        "start": "webpack serve --config build/webpack.dev.js",
        "dev": "webpack serve --config build/webpack.dev.js",
        "build": "webpack --config build/webpack.prod.js",
        "build:silent": "webpack --config build/webpack.prod.js --no-stats",
        "server": "nodemon --watch server server/index.js",
        "lint": "eslint src/",
        "lint:fix": "eslint . --fix"
    },
    "devDependencies": {
        "@kdcloudjs/auto-inject-css-webpack-plugin": "^1.0.0",
        "@kdcloudjs/eslint-config-kwc": "^1.0.2",
        "@kdcloudjs/eslint-plugin-kwc": "^1.0.2",
        "@kdcloudjs/kd-custom-control-cli": "^1.0.4",
        "copy-webpack-plugin": "^12.0.2",
        "css-minimizer-webpack-plugin": "^7.0.2",
        "eslint": "^9.35.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^28.14.0",
        "express": "^4.17.1",
        "fs-extra": "^11.2.0",
        "html-webpack-plugin": "5.6.0",
        "tslib": "^2.8.1",
        "webpack": "5.89.0",
        "webpack-cli": "5.1.4",
        "webpack-dev-server": "4.15.1",
        "webpack-merge": "^6.0.1",
        "webpackbar": "^6.0.1"
    },
    "nx": {
        "targets": {
            "build": {
                "outputs": [
                    "{projectRoot}/dist"
                ]
            }
        }
    },
    "dependencies": {
        "@kdcloudjs/kingdee-base-components": "^0.0.7",
        "@kdcloudjs/kwc": "1.0.0",
        "@kdcloudjs/kwc-shared-utils": "^0.0.3",
        "@kdcloudjs/kwc-webpack-plugin": "^1.0.0"
    }
}
